{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"outDir": "../out/test",
		"lib": ["ES2020"],
		"types": ["node", "mocha"],
		"sourceMap": true,
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"moduleResolution": "bundler"
	},
	"include": ["./**/*"],
	"exclude": ["node_modules"]
}
